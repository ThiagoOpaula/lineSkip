# Stage 1: Build the Rust app
FROM rust:1.80-slim as builder

# Set the working directory
WORKDIR /usr/src/app

# Install required dependencies
RUN apt-get update && apt-get install -y \
    pkg-config \
    libssl-dev \
    && rm -rf /var/lib/apt/lists/*

# Copy manifest files first for better caching
COPY Cargo.toml Cargo.lock ./

# Create dummy main.rs to cache dependencies
RUN mkdir src && echo "fn main() {}" > src/main.rs
RUN cargo build --release
RUN rm -rf src

# Copy actual source code
COPY src ./src

# Build the application
RUN cargo build --release

# Stage 2: Run the Rust app
FROM debian:bookworm-slim

# Install runtime dependencies
RUN apt-get update && apt-get install -y \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Set the working directory
WORKDIR /usr/src/app

# Copy the built application from the previous stage
COPY --from=builder /usr/src/app/target/release/lineskip-backend .

# Create a non-root user
RUN useradd -m -u 1001 lineskip && chown -R lineskip:lineskip /usr/src/app
USER lineskip

# Expose the port your application will run on
EXPOSE 8000

# Run the compiled Rust binary, not cargo
CMD ["./lineskip-backend"]